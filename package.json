{
  "name": "educonecta",
  "version": "0.1.0",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "seed:supabase": "npx tsx scripts/seed-supabase.ts",
    "setup:storage": "node --env-file .env scripts/setup-storage.mjs",
    "electron:dev": "ROLE=dev electron .",
    "electron:director": "ROLE=director electron .",
    "electron:docente": "ROLE=docente electron .",
    "electron:padre": "ROLE=padre electron .",
    "electron:alumno": "ROLE=alumno electron .",
    "electron:build:dev": "electron-builder --config electron/builder.yml --win --linux --mac --ia32",
    "electron:build:director": "cross-env ROLE=director electron-builder --config electron/builder.yml --win --linux --mac",
    "electron:build:docente": "cross-env ROLE=docente electron-builder --config electron/builder.yml --win --linux --mac",
    "electron:build:padre": "cross-env ROLE=padre electron-builder --config electron/builder.yml --win --linux --mac",
    "electron:build:alumno": "cross-env ROLE=alumno electron-builder --config electron/builder.yml --win --linux --mac"
  },
  "dependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "@headlessui/react": "^2.2.10",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@iconify/react": "^6.0.2",
    "@poursha98/react-ios-time-picker": "^2.0.3",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "dialkit": "^1.3.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.41.0",
    "html5-qrcode": "^2.3.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.0",
    "mysql2": "^3.22.5",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "^16.2.9"
  }
}
